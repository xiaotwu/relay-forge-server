# =============================================================================
# RelayForge Environment Configuration
# Copy this file to .env and modify values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
RELAY_ENV=development
RELAY_LOG_LEVEL=debug
RELAY_LOG_FORMAT=json

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=http://localhost:8080
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5174

# -----------------------------------------------------------------------------
# Realtime Service
# -----------------------------------------------------------------------------
REALTIME_HOST=0.0.0.0
REALTIME_PORT=8081
REALTIME_MAX_CONNECTIONS=10000

# -----------------------------------------------------------------------------
# Media Service
# -----------------------------------------------------------------------------
MEDIA_HOST=0.0.0.0
MEDIA_PORT=8082

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=relayforge
DB_PASSWORD=relayforge_dev
DB_NAME=relayforge
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300

# -----------------------------------------------------------------------------
# Valkey / Redis
# -----------------------------------------------------------------------------
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=
VALKEY_DB=0
VALKEY_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
AUTH_JWT_SECRET=change-me-in-production-use-a-strong-random-string
AUTH_JWT_ACCESS_TTL=15m
AUTH_JWT_REFRESH_TTL=7d
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_MAX_DEVICES_PER_USER=10
AUTH_TOTP_ISSUER=RelayForge

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@relayforge.local
SMTP_TLS=false
EMAIL_VERIFICATION_ENABLED=false

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://localhost:9000
S3_INTERNAL_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=relay-uploads
S3_BUCKET_AVATARS=relay-avatars
S3_BUCKET_EMOJI=relay-emoji
S3_USE_PATH_STYLE=true
S3_PRESIGN_EXPIRY=3600

# -----------------------------------------------------------------------------
# LiveKit
# -----------------------------------------------------------------------------
LIVEKIT_HOST=localhost
LIVEKIT_PORT=7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_INTERNAL_URL=ws://livekit:7880

# -----------------------------------------------------------------------------
# Antivirus (ClamAV)
# -----------------------------------------------------------------------------
ANTIVIRUS_ENABLED=false
ANTIVIRUS_HOST=localhost
ANTIVIRUS_PORT=3310

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=10
RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# Upload Limits
# -----------------------------------------------------------------------------
UPLOAD_MAX_FILE_SIZE=52428800
UPLOAD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/gif,image/webp,image/apng,video/mp4,video/webm,audio/mpeg,audio/ogg,audio/webm,application/pdf,text/plain
UPLOAD_CHUNK_SIZE=5242880

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=relayforge

# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9090
